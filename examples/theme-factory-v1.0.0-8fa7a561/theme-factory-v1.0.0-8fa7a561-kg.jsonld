    },
    {
      "@id": "rule:show_theme_showcase",
      "@type": "skill:Rule",
      "rdfs:label": "Display the theme-showcase.pdf file to allow users to see all available themes visually",
      "aether:origin": "core"
    },
    {
      "@id": "rule:do_not_modify_showcase",
      "@type": "skill:Rule",
      "rdfs:label": "Do not make any modifications to theme-showcase.pdf",
      "aether:origin": "core"
    },
    {
      "@id": "rule:show_for_viewing_only",
      "@type": "skill:Rule",
      "rdfs:label": "Simply show the file for viewing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ask_for_theme_choice",
      "@type": "skill:Rule",
      "rdfs:label": "Ask which theme to apply to the deck",
      "aether:origin": "core"
    },
    {
      "@id": "rule:wait_for_selection",
      "@type": "skill:Rule",
      "rdfs:label": "Get explicit confirmation about the chosen theme",
      "aether:origin": "core"
    },
    {
      "@id": "rule:follow_four_step_process",
      "@type": "skill:Rule",
      "rdfs:label": "Follow the four-step usage process: show showcase, ask for choice, wait for selection, apply theme",
      "aether:origin": "core"
    },
    {
      "@id": "rule:apply_consistently_throughout",
      "@type": "skill:Rule",
      "rdfs:label": "Apply the specified colors and fonts consistently throughout the deck",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ensure_proper_contrast",
      "@type": "skill:Rule",
      "rdfs:label": "Ensure proper contrast and readability",
      "aether:origin": "core"
    },
    {
      "@id": "rule:maintain_visual_identity",
      "@type": "skill:Rule",
      "rdfs:label": "Maintain the theme's visual identity across all slides",
      "aether:origin": "core"
    },
    {
      "@id": "rule:read_theme_file",
      "@type": "skill:Rule",
      "rdfs:label": "Read the corresponding theme file from the themes/ directory",
      "aether:origin": "core"
    },
    {
      "@id": "rule:create_custom_when_needed",
      "@type": "skill:Rule",
      "rdfs:label": "Create a custom theme when none of the existing themes work for an artifact",
      "aether:origin": "core"
    },
    {
      "@id": "technique:four_step_usage",
      "@type": "skill:Technique",
      "rdfs:label": "Four-step usage process",
      "aether:origin": "core",
      "skill:contains": [
        "technique:show_showcase",
        "technique:ask_choice",
        "technique:wait_confirmation",
        "technique:apply_theme"
      ]
    },
    {
      "@id": "technique:show_showcase",
      "@type": "skill:Technique",
      "rdfs:label": "Show the theme showcase",
      "aether:origin": "core"
    },
    {
      "@id": "technique:ask_choice",
      "@type": "skill:Technique",
      "rdfs:label": "Ask for their choice",
      "aether:origin": "core"
    },
    {
      "@id": "technique:wait_confirmation",
      "@type": "skill:Technique",
      "rdfs:label": "Wait for selection",
      "aether:origin": "core"
    },
    {
      "@id": "technique:apply_theme",
      "@type": "skill:Technique",
      "rdfs:label": "Apply the theme",
      "aether:origin": "core"
    },
    {
      "@id": "technique:theme_application",
      "@type": "skill:Technique",
      "rdfs:label": "Theme application process",
      "aether:origin": "core",
      "skill:requires": [
        "rule:read_theme_file",
        "rule:apply_consistently_throughout",
        "rule:ensure_proper_contrast",
        "rule:maintain_visual_identity"
      ]
    },
    {
      "@id": "technique:generate_new_theme",
      "@type": "skill:Technique",
      "rdfs:label": "Generate a new theme based on provided inputs",
      "aether:origin": "core"
    },
    {
      "@id": "technique:show_for_review",
      "@type": "skill:Technique",
      "rdfs:label": "Show theme for review and verification",
      "aether:origin": "core"
    },
