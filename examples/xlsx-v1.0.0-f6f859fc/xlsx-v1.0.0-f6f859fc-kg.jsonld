      ],
      "skill:avoids": [
        "antipattern:ref_errors",
        "antipattern:div_zero_errors",
        "antipattern:value_errors",
        "antipattern:na_errors",
        "antipattern:name_errors"
      ]
    },
    {
      "@id": "concept:professional_formatting",
      "@type": "skill:Concept",
      "rdfs:label": "Professional Formatting",
      "aether:origin": "core",
      "skill:contains": [
