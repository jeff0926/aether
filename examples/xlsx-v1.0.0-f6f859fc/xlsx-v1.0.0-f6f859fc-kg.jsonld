  },
  "@graph": [
    {
      "@id": "persona:excel_financial_engineer",
      "@type": "skill:Trait",
      "rdfs:label": "Excel Financial Engineer",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:zero_formula_errors",
        "concept:professional_formatting",
        "concept:formula_architecture"
      ],
      "skill:contains": [
