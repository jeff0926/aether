        "concept:color_coding_standards",
        "concept:number_formatting_standards"
      ],
      "skill:rules": [
        "rule:professional_font_usage"
      ]
    },
    {
      "@id": "concept:formula_architecture",
      "@type": "skill:Concept",
      "rdfs:label": "Formula Architecture",
      "aether:origin": "core",
      "skill:contains": [
        "concept:assumptions_placement",
        "concept:formula_construction"
      ],
      "skill:techniques": [
        "technique:assumptions_placement",
        "technique:formula_construction",
        "technique:formula_error_prevention"
      ],
      "skill:avoids": [
        "antipattern:hardcoded_values_in_formulas"
      ]
    },
    {
      "@id": "concept:professional_font",
      "@type": "skill:Concept",
      "rdfs:label": "Professional Font",
      "aether:origin": "core",
      "skill:rules": [
        "rule:professional_font_usage"
      ]
    },
    {
      "@id": "concept:color_coding_standards",
      "@type": "skill:Concept",
      "rdfs:label": "Color Coding Standards",
      "aether:origin": "core",
      "skill:contains": [
        "concept:industry_standard_color_conventions"
      ],
      "skill:rules": [
        "rule:blue_text_inputs",
        "rule:black_text_formulas",
        "rule:green_text_internal_links",
        "rule:red_text_external_links",
        "rule:yellow_background_key_assumptions"
      ]
    },
    {
      "@id": "concept:industry_standard_color_conventions",
      "@type": "skill:Concept",
      "rdfs:label": "Industry Standard Color Conventions",
      "aether:origin": "core",
      "skill:rules": [
        "rule:blue_text_inputs",
        "rule:black_text_formulas",
        "rule:green_text_internal_links",
        "rule:red_text_external_links",
        "rule:yellow_background_key_assumptions"
      ]
    },
    {
      "@id": "concept:number_formatting_standards",
      "@type": "skill:Concept",
      "rdfs:label": "Number Formatting Standards",
      "aether:origin": "core",
      "skill:rules": [
        "rule:years_as_text_strings",
        "rule:currency_format_with_units",
        "rule:zeros_formatted_as_dash",
        "rule:percentages_one_decimal",
        "rule:multiples_format",
        "rule:negative_parentheses"
      ]
    },
    {
      "@id": "concept:assumptions_placement",
      "@type": "skill:Concept",
      "rdfs:label": "Assumptions Placement",
      "aether:origin": "core",
      "skill:rules": [
        "rule:separate_assumption_cells",
        "rule:use_cell_references",
        "rule:documentation_for_hardcodes"
      ],
      "skill:techniques": [
        "technique:assumptions_placement"
      ]
    },
    {
      "@id": "concept:formula_construction",
      "@type": "skill:Concept",
      "rdfs:label": "Formula Construction",
      "aether:origin": "core",
      "skill:rules": [
        "rule:separate_assumption_cells",
        "rule:use_cell_references"
      ],
      "skill:techniques": [
        "technique:formula_construction",
        "technique:formula_error_prevention"
      ]
    },
    {
      "@id": "concept:common_workflow",
      "@type": "skill:Concept",
      "rdfs:label": "Common Workflow",
      "aether:origin": "core",
      "skill:contains": [
        "concept:tool_selection",
        "concept:mandatory_recalculation",
        "concept:error_verification"
      ],
      "skill:rules": [
        "rule:mandatory_recalculation",
        "rule:verify_and_fix_errors"
      ]
    },
    {
      "@id": "concept:tool_selection",
      "@type": "skill:Concept",
      "rdfs:label": "Tool Selection",
      "aether:origin": "core",
      "skill:rules": [
        "rule:pandas_for_data_openpyxl_for_formulas"
      ]
    },
    {
      "@id": "concept:mandatory_recalculation",
      "@type": "skill:Concept",
      "rdfs:label": "Mandatory Recalculation",
      "aether:origin": "core",
      "skill:rules": [
        "rule:mandatory_recalculation"
      ],
      "skill:requires": [
        "tool:libreoffice",
        "tool:recalc_script"
      ]
    },
    {
      "@id": "concept:error_verification",
      "@type": "skill:Concept",
      "rdfs:label": "Error Verification",
      "aether:origin": "core",
      "skill:rules": [
        "rule:verify_and_fix_errors"
      ],
      "skill:techniques": [
        "technique:error_identification"
      ]
    },
    {
      "@id": "concept:xlsx_workflows",
      "@type": "skill:Concept",
      "rdfs:label": "XLSX Workflows",
      "aether:origin": "core",
      "skill:contains": [
        "concept:data_analysis",
        "concept:excel_file_workflows",
        "concept:creating_new_files"
      ],
      "skill:techniques": [
        "technique:pandas_data_analysis",
        "technique:openpyxl_formulas"
      ]
    },
    {
      "@id": "concept:data_analysis",
      "@type": "skill:Concept",
      "rdfs:label": "Data Analysis",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:pandas_data_analysis"
      ]
    },
    {
      "@id": "concept:excel_file_workflows",
      "@type": "skill:Concept",
      "rdfs:label": "Excel File Workflows",
      "aether:origin": "core",
      "skill:rules": [
        "rule:use_formulas_not_hardcoded"
      ],
      "skill:avoids": [
        "antipattern:hardcoded_calculated_values"
      ]
    },
    {
      "@id": "concept:creating_new_files",
      "@type": "skill:Concept",
      "rdfs:label": "Creating New Files",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:openpyxl_formulas"
      ]
    },
    {
      "@id": "rule:zero_formula_errors",
      "@type": "skill:Rule",
      "rdfs:label": "Every Excel model MUST be delivered with ZERO formula errors",
      "aether:origin": "core"
    },
    {
      "@id": "rule:professional_font_usage",
      "@type": "skill:Rule",
      "rdfs:label": "Use consistent professional font (Arial, Times New Roman) unless instructed otherwise",
      "aether:origin": "core"
    },
    {
      "@id": "rule:preserve_existing_templates",
      "@type": "skill:Rule",
      "rdfs:label": "Study and EXACTLY match existing format, style, and conventions when modifying files",
      "aether:origin": "core"
    },
    {
      "@id": "rule:existing_overrides_guidelines",
      "@type": "skill:Rule",
      "rdfs:label": "Existing template conventions ALWAYS override these guidelines",
      "aether:origin": "core"
    },
    {
      "@id": "rule:blue_text_inputs",
      "@type": "skill:Rule",
      "rdfs:label": "Blue text (RGB: 0,0,255) for hardcoded inputs and numbers users will change",
      "aether:origin": "core"
    },
    {
      "@id": "rule:black_text_formulas",
      "@type": "skill:Rule",
      "rdfs:label": "Black text (RGB: 0,0,0) for ALL formulas and calculations",
      "aether:origin": "core"
    },
    {
      "@id": "rule:green_text_internal_links",
      "@type": "skill:Rule",
      "rdfs:label": "Green text (RGB: 0,128,0) for links pulling from other worksheets within same workbook",
      "aether:origin": "core"
    },
    {
      "@id": "rule:red_text_external_links",
      "@type": "skill:Rule",
      "rdfs:label": "Red text (RGB: 255,0,0) for external links to other files",
      "aether:origin": "core"
    },
    {
      "@id": "rule:yellow_background_key_assumptions",
      "@type": "skill:Rule",
      "rdfs:label": "Yellow background (RGB: 255,255,0) for key assumptions needing attention",
      "aether:origin": "core"
    },
    {
      "@id": "rule:years_as_text_strings",
      "@type": "skill:Rule",
      "rdfs:label": "Format years as text strings (2024 not 2,024)",
      "aether:origin": "core"
    },
    {
      "@id": "rule:currency_format_with_units",
      "@type": "skill:Rule",
      "rdfs:label": "Use $#,##0 format and ALWAYS specify units in headers (Revenue ($mm))",
      "aether:origin": "core"
    },
    {
      "@id": "rule:zeros_formatted_as_dash",
      "@type": "skill:Rule",
      "rdfs:label": "Use number formatting to make all zeros dash (-), including percentages",
      "aether:origin": "core"
    },
    {
      "@id": "rule:percentages_one_decimal",
      "@type": "skill:Rule",
      "rdfs:label": "Default to 0.0% format (one decimal) for percentages",
      "aether:origin": "core"
    },
    {
      "@id": "rule:multiples_format",
      "@type": "skill:Rule",
      "rdfs:label": "Format as 0.0x for valuation multiples (EV/EBITDA, P/E)",
      "aether:origin": "core"
    },
    {
      "@id": "rule:negative_parentheses",
      "@type": "skill:Rule",
      "rdfs:label": "Use parentheses (123) not minus -123 for negative numbers",
      "aether:origin": "core"
    },
    {
      "@id": "rule:separate_assumption_cells",
      "@type": "skill:Rule",
      "rdfs:label": "Place ALL assumptions (growth rates, margins, multiples) in separate assumption cells",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_cell_references",
      "@type": "skill:Rule",
      "rdfs:label": "Use cell references instead of hardcoded values in formulas",
      "aether:origin": "core"
    },
    {
      "@id": "rule:documentation_for_hardcodes",
      "@type": "skill:Rule",
      "rdfs:label": "Comment hardcodes with Source: [System/Document], [Date], [Specific Reference], [URL if applicable]",
      "aether:origin": "core"
    },
    {
      "@id": "rule:verify_cell_references",
      "@type": "skill:Rule",
      "rdfs:label": "Verify all cell references are correct",
      "aether:origin": "core"
    },
    {
      "@id": "rule:mandatory_recalculation",
      "@type": "skill:Rule",
      "rdfs:label": "MANDATORY IF USING FORMULAS: Use scripts/recalc.py script",
      "aether:origin": "core"
    },
    {
      "@id": "rule:verify_and_fix_errors",
      "@type": "skill:Rule",
      "rdfs:label": "Check error_summary for specific error types and fix identified errors",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_formulas_not_hardcoded",
      "@type": "skill:Rule",
      "rdfs:label": "Always use Excel formulas instead of calculating values in Python and hardcoding them",
      "aether:origin": "core"
    },
    {
      "@id": "rule:pandas_for_data_openpyxl_for_formulas",
      "@type": "skill:Rule",
      "rdfs:label": "Choose pandas for data, openpyxl for formulas and formatting",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:ref_errors",
      "@type": "skill:AntiPattern",
      "rdfs:label": "#REF! errors - Invalid cell references",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:div_zero_errors",
      "@type": "skill:AntiPattern",
      "rdfs:label": "#DIV/0! errors - Division by zero",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:value_errors",
      "@type": "skill:AntiPattern",
      "rdfs:label": "#VALUE! errors - Wrong data type in formula",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:na_errors",
      "@type": "skill:AntiPattern",
      "rdfs:label": "#N/A errors",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:name_errors",
      "@type": "skill:AntiPattern",
      "rdfs:label": "#NAME? errors - Unrecognized formula name",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:hardcoded_values_in_formulas",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Hardcoded values in formulas instead of cell references",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:hardcoded_calculated_values",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Calculating in Python and hardcoding results",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:impose_standardized_formatting",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Never impose standardized formatting on files with established patterns",
      "aether:origin": "core"
    },
    {
      "@id": "technique:assumptions_placement",
      "@type": "skill:Technique",
      "rdfs:label": "Place assumptions in separate cells and reference them",
      "aether:origin": "core"
    },
    {
      "@id": "technique:formula_construction",
      "@type": "skill:Technique",
      "rdfs:label": "Build formulas with cell references instead of hardcoded values",
      "aether:origin": "core"
    },
    {
      "@id": "technique:formula_error_prevention",
      "@type": "skill:Technique",
      "rdfs:label": "Check ranges, test edge cases, verify no circular references",
      "aether:origin": "core"
    },
    {
      "@id": "technique:error_identification",
      "@type": "skill:Technique",
      "rdfs:label": "Check error_summary JSON for specific error types and locations",
      "aether:origin": "core"
    },
    {
      "@id": "technique:pandas_data_analysis",
      "@type": "skill:Technique",
      "rdfs:label": "Use pandas for data analysis, visualization, and basic operations",
      "aether:origin": "core"
    },
    {
      "@id": "technique:openpyxl_formulas",
      "@type": "skill:Technique",
      "rdfs:label": "Use openpyxl for formulas and formatting in Excel files",
      "aether:origin": "core"
    },
    {
      "@id": "technique:libreoffice_recalculation",
      "@type": "skill:Technique",
      "rdfs:label": "Use LibreOffice for recalculating formula values via scripts/recalc.py",
      "aether:origin": "core"
    },
    {
      "@id": "tool:libreoffice",
      "@type": "skill:Tool",
      "rdfs:label": "LibreOffice",
      "aether:origin": "core"
    },
    {
      "@id": "tool:recalc_script",
      "@type": "skill:Tool",
      "rdfs:label": "scripts/recalc.py",
      "aether:origin": "core"
    },
    {
      "@id": "tool:pandas",
      "@type": "skill:Tool",
      "rdfs:label": "pandas",
      "aether:origin": "core",
      "skill:pairs_with": [
        "concept:data_analysis"
      ]
    },
    {
      "@id": "tool:openpyxl",
      "@type": "skill:Tool",
      "rdfs:label": "openpyxl",
      "aether:origin": "core",
      "skill:pairs_with": [
        "concept:formula_architecture",
        "concept:professional_formatting"
      ]
    }
  ]
}