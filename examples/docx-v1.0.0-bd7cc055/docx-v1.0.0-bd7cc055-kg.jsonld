{
  "@context": {
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "aether": "http://aether.dev/ontology#",
    "skill": "http://aether.dev/skill#"
  },
  "@graph": [
    {
      "@id": "persona:document_engineer",
      "@type": "skill:Trait",
      "rdfs:label": "Document Engineer",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:validation",
        "concept:compatibility",
        "concept:xml_standards"
      ],
      "skill:contains": [
        "trait:detail_oriented",
        "trait:technical",
        "trait:perfectionist",
        "trait:systematic",
        "trait:cautious"
      ]
    },
    {
      "@id": "trait:detail_oriented",
      "@type": "skill:Trait",
      "rdfs:label": "Detail Oriented",
      "aether:origin": "core",
      "skill:enables": [
        "rule:always_validate_output",
        "rule:set_dual_table_widths"
      ]
    },
    {
      "@id": "trait:technical",
      "@type": "skill:Trait",
      "rdfs:label": "Technical",
      "aether:origin": "core",
      "skill:enables": [
        "technique:xml_manipulation",
        "technique:zip_archive_handling"
      ]
    },
    {
      "@id": "trait:perfectionist",
      "@type": "skill:Trait",
      "rdfs:label": "Perfectionist",
      "aether:origin": "core",
      "skill:requires": [
        "rule:explicit_page_size",
        "rule:override_builtin_styles"
      ]
    },
    {
      "@id": "trait:systematic",
      "@type": "skill:Trait",
      "rdfs:label": "Systematic",
      "aether:origin": "core",
      "skill:enables": [
        "technique:unpack_edit_repack",
        "technique:structured_validation"
      ]
    },
    {
      "@id": "trait:cautious",
      "@type": "skill:Trait",
      "rdfs:label": "Cautious",
      "aether:origin": "core",
      "skill:enables": [
        "rule:convert_doc_before_editing",
        "rule:use_dxa_units"
      ]
    },
    {
      "@id": "concept:docx_structure",
      "@type": "skill:Concept",
      "rdfs:label": "DOCX Structure",
      "aether:origin": "core",
      "skill:contains": [
        "concept:zip_archive",
        "concept:xml_files"
      ],
      "skill:rules": [
        "rule:docx_is_zip_archive"
      ]
    },
    {
      "@id": "concept:zip_archive",
      "@type": "skill:Concept",
      "rdfs:label": "ZIP Archive",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:unpack_edit_repack"
      ]
    },
    {
      "@id": "concept:xml_files",
      "@type": "skill:Concept",
      "rdfs:label": "XML Files",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:xml_manipulation",
        "technique:raw_xml_access"
      ]
    },
    {
      "@id": "concept:content_reading",
      "@type": "skill:Concept",
      "rdfs:label": "Content Reading",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:pandoc_extraction",
        "technique:raw_xml_access"
      ]
    },
    {
      "@id": "concept:document_creation",
      "@type": "skill:Concept",
      "rdfs:label": "Document Creation",
      "aether:origin": "core",
      "skill:requires": [
        "tool:docx_js"
      ],
      "skill:rules": [
        "rule:always_validate_output",
        "rule:explicit_page_size"
      ],
      "skill:techniques": [
        "technique:javascript_generation"
      ]
    },
    {
      "@id": "concept:document_editing",
      "@type": "skill:Concept",
      "rdfs:label": "Document Editing",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:unpack_edit_repack"
      ],
      "skill:rules": [
        "rule:convert_doc_before_editing"
      ]
    },
    {
      "@id": "concept:page_sizing",
      "@type": "skill:Concept",
      "rdfs:label": "Page Sizing",
      "aether:origin": "core",
      "skill:rules": [
        "rule:explicit_page_size",
        "rule:use_dxa_units"
      ],
      "skill:avoids": [
        "antipattern:default_a4",
        "antipattern:percentage_widths"
      ]
    },
    {
      "@id": "concept:styling",
      "@type": "skill:Concept",
      "rdfs:label": "Styling",
      "aether:origin": "core",
      "skill:rules": [
        "rule:override_builtin_styles",
        "rule:use_arial_default",
        "rule:keep_titles_black"
      ],
      "skill:techniques": [
        "technique:exact_style_ids"
      ]
    },
    {
      "@id": "concept:lists",
      "@type": "skill:Concept",
      "rdfs:label": "Lists",
      "aether:origin": "core",
      "skill:rules": [
        "rule:use_numbering_config"
      ],
      "skill:avoids": [
        "antipattern:unicode_bullets",
        "antipattern:manual_bullet_characters"
      ]
    },
    {
      "@id": "concept:tables",
      "@type": "skill:Concept",
      "rdfs:label": "Tables",
      "aether:origin": "core",
      "skill:rules": [
        "rule:set_dual_table_widths",
        "rule:use_dxa_units",
        "rule:use_shading_clear"
      ],
      "skill:avoids": [
        "antipattern:percentage_widths",
        "antipattern:shading_solid"
      ]
    },
    {
      "@id": "concept:validation",
      "@type": "skill:Concept",
      "rdfs:label": "Validation",
      "aether:origin": "core",
      "skill:rules": [
        "rule:always_validate_output"
      ],
      "skill:techniques": [
        "technique:structured_validation"
      ]
    },
    {
      "@id": "concept:compatibility",
      "@type": "skill:Concept",
      "rdfs:label": "Compatibility",
      "aether:origin": "core",
      "skill:rules": [
        "rule:use_arial_default",
        "rule:use_dxa_units"
      ],
      "skill:avoids": [
        "antipattern:percentage_widths"
      ]
    },
    {
      "@id": "concept:xml_standards",
      "@type": "skill:Concept",
      "rdfs:label": "XML Standards",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:xml_manipulation"
      ]
    },
    {
      "@id": "rule:docx_is_zip_archive",
      "@type": "skill:Rule",
      "rdfs:label": "A .docx file is a ZIP archive containing XML files",
      "aether:origin": "core"
    },
    {
      "@id": "rule:convert_doc_before_editing",
      "@type": "skill:Rule",
      "rdfs:label": "Legacy .doc files must be converted before editing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:always_validate_output",
      "@type": "skill:Rule",
      "rdfs:label": "After creating the file, validate it",
      "aether:origin": "core"
    },
    {
      "@id": "rule:explicit_page_size",
      "@type": "skill:Rule",
      "rdfs:label": "Always set page size explicitly for consistent results",
      "aether:origin": "core"
    },
    {
      "@id": "rule:override_builtin_styles",
      "@type": "skill:Rule",
      "rdfs:label": "Use exact IDs to override built-in styles",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_arial_default",
      "@type": "skill:Rule",
      "rdfs:label": "Use Arial as the default font (universally supported)",
      "aether:origin": "core"
    },
    {
      "@id": "rule:keep_titles_black",
      "@type": "skill:Rule",
      "rdfs:label": "Keep titles black for readability",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_numbering_config",
      "@type": "skill:Rule",
      "rdfs:label": "Use numbering config with LevelFormat.BULLET",
      "aether:origin": "core"
    },
    {
      "@id": "rule:set_dual_table_widths",
      "@type": "skill:Rule",
      "rdfs:label": "Tables need dual widths - set both columnWidths on the table AND width on each cell",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_dxa_units",
      "@type": "skill:Rule",
      "rdfs:label": "Always use DXA units",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_shading_clear",
      "@type": "skill:Rule",
      "rdfs:label": "Use ShadingType.CLEAR (not SOLID) to prevent black backgrounds",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:default_a4",
      "@type": "skill:AntiPattern",
      "rdfs:label": "docx-js defaults to A4, not US Letter",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:unicode_bullets",
      "@type": "skill:AntiPattern",
      "rdfs:label": "NEVER use unicode bullets",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:manual_bullet_characters",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Never manually insert bullet characters",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:percentage_widths",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Percentages break in Google Docs",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:shading_solid",
      "@type": "skill:AntiPattern",
      "rdfs:label": "ShadingType.SOLID causes black backgrounds",
      "aether:origin": "core"
    },
    {
      "@id": "technique:pandoc_extraction",
      "@type": "skill:Technique",
      "rdfs:label": "Text extraction with pandoc --track-changes=all",
      "aether:origin": "core",
      "skill:pairs_with": [
        "tool:pandoc"
      ]
    },
    {
      "@id": "technique:raw_xml_access",
      "@type": "skill:Technique",
      "rdfs:label": "Raw XML access via unpacking",
      "aether:origin": "core",
      "skill:pairs_with": [
        "tool:unpack_script"
      ]
    },
    {
      "@id": "technique:unpack_edit_repack",
      "@type": "skill:Technique",
      "rdfs:label": "Unpack → edit XML → repack",
      "aether:origin": "core"
    },
    {
      "@id": "technique:javascript_generation",
      "@type": "skill:Technique",
      "rdfs:label": "Generate .docx files with JavaScript, then validate",
      "aether:origin": "core",
      "skill:pairs_with": [
        "tool:docx_js"
      ]
    },
    {
      "@id": "technique:structured_validation",
      "@type": "skill:Technique",
      "rdfs:label": "If validation fails, unpack, fix the XML, and repack",
      "aether:origin": "core",
      "skill:pairs_with": [
        "tool:validate_script"
      ]
    },
    {
      "@id": "technique:xml_manipulation",
      "@type": "skill:Technique",
      "rdfs:label": "Direct XML editing and manipulation",
      "aether:origin": "core"
    },
    {
      "@id": "technique:exact_style_ids",
      "@type": "skill:Technique",
      "rdfs:label": "Use exact IDs like 'Heading1', 'Heading2' to override built-in styles",
      "aether:origin": "core"
    },
    {
      "@id": "technique:zip_archive_handling",
      "@type": "skill:Technique",
      "rdfs:label": "Treating DOCX as ZIP archive for manipulation",
      "aether:origin": "core"
    },
    {
      "@id": "tool:pandoc",
      "@type": "skill:Tool",
      "rdfs:label": "Pandoc",
      "aether:origin": "core"
    },
    {
      "@id": "tool:docx_js",
      "@type": "skill:Tool",
      "rdfs:label": "docx-js",
      "aether:origin": "core"
    },
    {
      "@id": "tool:libreoffice",
      "@type": "skill:Tool",
      "rdfs:label": "LibreOffice",
      "aether:origin": "core"
    },
    {
      "@id": "tool:unpack_script",
      "@type": "skill:Tool",
      "rdfs:label": "Python unpack.py script",
      "aether:origin": "core"
    },
    {
      "@id": "tool:validate_script",
      "@type": "skill:Tool",
      "rdfs:label": "Python validate.py script",
      "aether:origin": "core"
    },
    {
      "@id": "tool:soffice_script",
      "@type": "skill:Tool",
      "rdfs:label": "Python soffice.py script",
      "aether:origin": "core"
    },
    {
      "@id": "tool:accept_changes_script",
      "@type": "skill:Tool",
      "rdfs:label": "Python accept_changes.py script",
      "aether:origin": "core"
    }
  ]
}