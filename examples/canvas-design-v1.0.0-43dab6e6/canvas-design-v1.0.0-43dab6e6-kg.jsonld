      "skill:techniques": [
        "technique:precision_alignment",
        "technique:chromatic_calibration",
        "technique:meditation_practice_care"
      ]
    },
    {
      "@id": "concept:deep_expertise",
      "@type": "skill:Concept",
      "rdfs:label": "Deep Expertise",
      "aether:origin": "core",
      "skill:enables": [
        "concept:artistic_freedom",
        "concept:interpretive_choices"
      ]
    },
    {
      "@id": "concept:movement_naming",
      "@type": "skill:Concept",
      "rdfs:label": "Movement Naming",
      "aether:origin": "core",
      "skill:rules": [
        "rule:one_to_two_words",
        "rule:evocative_combinations"
      ]
    },
    {
      "@id": "concept:manifesto_writing",
      "@type": "skill:Concept",
      "rdfs:label": "Manifesto Writing",
      "aether:origin": "core",
      "skill:rules": [
        "rule:four_to_six_paragraphs",
        "rule:concise_but_complete",
        "rule:poetic_design_philosophy"
      ]
    },
    {
      "@id": "concept:spatial_communication",
      "@type": "skill:Concept",
      "rdfs:label": "Spatial Communication",
      "aether:origin": "core",
      "skill:rules": [
        "rule:ideas_through_space_not_text",
        "rule:structure_communicates"
      ]
    },
    {
      "@id": "concept:pure_design",
      "@type": "skill:Concept",
      "rdfs:label": "Pure Design",
      "aether:origin": "core",
      "skill:rules": [
        "rule:art_objects_not_decorated_documents",
        "rule:information_lives_in_design"
      ]
    },
    {
      "@id": "concept:artistic_freedom",
      "@type": "skill:Concept",
      "rdfs:label": "Artistic Freedom",
      "aether:origin": "core",
      "skill:rules": [
        "rule:leave_creative_space",
        "rule:room_for_interpretation"
      ]
    },
    {
      "@id": "rule:two_step_process",
      "@type": "skill:Rule",
      "rdfs:label": "Complete in two steps: Philosophy Creation then Visual Expression",
      "aether:origin": "core"
    },
    {
      "@id": "rule:output_specific_formats",
      "@type": "skill:Rule",
      "rdfs:label": "Output only .md, .pdf, and .png files",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ninety_percent_visual_ten_percent_text",
      "@type": "skill:Rule",
      "rdfs:label": "Artifacts must be 90% visual design, 10% essential text",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_redundancy",
      "@type": "skill:Rule",
      "rdfs:label": "Each design aspect mentioned once, avoid repeating points",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:redundant_design_aspects"
      ]
    },
    {
      "@id": "rule:emphasize_craftsmanship_repeatedly",
      "@type": "skill:Rule",
      "rdfs:label": "Stress multiple times that work appears to take countless hours",
      "aether:origin": "core",
      "skill:requires": [
        "concept:master_level_execution"
      ]
    },
    {
      "@id": "rule:leave_creative_space",
      "@type": "skill:Rule",
      "rdfs:label": "Remain specific but concise for interpretive choices",
      "aether:origin": "core",
      "skill:enables": [
        "concept:artistic_freedom"
      ]
    },
    {
      "@id": "rule:one_to_two_words",
      "@type": "skill:Rule",
      "rdfs:label": "Name the movement in 1-2 words",
      "aether:origin": "core"
    },
    {
      "@id": "rule:four_to_six_paragraphs",
      "@type": "skill:Rule",
      "rdfs:label": "Design philosophy should be 4-6 paragraphs long",
      "aether:origin": "core"
    },
    {
      "@id": "rule:concise_but_complete",
      "@type": "skill:Rule",
      "rdfs:label": "Philosophy must be concise but complete",
      "aether:origin": "core"
    },
    {
      "@id": "rule:evocative_combinations",
      "@type": "skill:Rule",
      "rdfs:label": "Use evocative word combinations like 'Brutalist Joy' or 'Chromatic Silence'",
      "aether:origin": "core"
    },
    {
      "@id": "rule:countless_hours_appearance",
      "@type": "skill:Rule",
      "rdfs:label": "Final work must appear as though it took countless hours to create",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ideas_through_space_not_text",
      "@type": "skill:Rule",
      "rdfs:label": "Ideas communicate through space, form, color, composition - not paragraphs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:information_through_design",
      "@type": "skill:Rule",
      "rdfs:label": "Information lives in design, not paragraphs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:text_as_visual_gesture",
      "@type": "skill:Rule",
      "rdfs:label": "Text as rare, powerful gesture - never paragraphs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:structure_communicates",
      "@type": "skill:Rule",
      "rdfs:label": "Structure communicates, not words",
      "aether:origin": "core"
    },
    {
      "@id": "rule:art_objects_not_decorated_documents",
      "@type": "skill:Rule",
      "rdfs:label": "This is about making art objects, not documents with decoration",
      "aether:origin": "core"
    },
    {
      "@id": "rule:room_for_interpretation",
      "@type": "skill:Rule",
      "rdfs:label": "Provide room for next Claude to make interpretive choices",
      "aether:origin": "core"
    },
    {
      "@id": "rule:poetic_design_philosophy",
      "@type": "skill:Rule",
      "rdfs:label": "Fill with poetic design philosophy that brings together core vision",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:layouts_templates",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Layouts or templates instead of visual philosophy",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:text_heavy_design",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Text-heavy design instead of visual communication",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:redundant_design_aspects",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Repeating points about color theory, spatial relationships, or typography",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:lengthy_text",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Lengthy explanatory text blocks instead of minimal essential words",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:decorated_documents",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Documents with decoration instead of pure art objects",
      "aether:origin": "core"
    },
    {
      "@id": "technique:form_space_color_composition",
      "@type": "skill:Technique",
      "rdfs:label": "Express through form, space, color, composition",
      "aether:origin": "core"
    },
    {
      "@id": "technique:minimal_text_accent",
      "@type": "skill:Technique",
      "rdfs:label": "Use minimal text as visual accent",
      "aether:origin": "core"
    },
    {
      "@id": "technique:monumental_form",
      "@type": "skill:Technique",
      "rdfs:label": "Communication through monumental form and bold geometry",
      "aether:origin": "core"
    },
    {
      "@id": "technique:spatial_tension",
      "@type": "skill:Technique",
      "rdfs:label": "Express ideas through visual weight and spatial tension",
      "aether:origin": "core"
    },
    {
      "@id": "technique:sculptural_typography",
      "@type": "skill:Technique",
      "rdfs:label": "Sculptural typography with huge single words, tiny labels",
      "aether:origin": "core"
    },
    {
      "@id": "technique:chromatic_information_system",
      "@type": "skill:Technique",
      "rdfs:label": "Color as the primary information system",
      "aether:origin": "core"
    },
    {
      "@id": "technique:color_zone_meaning",
      "@type": "skill:Technique",
      "rdfs:label": "Color zones create meaning through geometric precision",
      "aether:origin": "core"
    },
    {
      "@id": "technique:chromatic_calibration",
      "@type": "skill:Technique",
      "rdfs:label": "Painstaking chromatic calibration",
      "aether:origin": "core"
    },
    {
      "@id": "technique:negative_space",
      "@type": "skill:Technique",
      "rdfs:label": "Vast negative space for quiet visual contemplation",
      "aether:origin": "core"
    },
    {
      "@id": "technique:organic_clustering",
      "@type": "skill:Technique",
      "rdfs:label": "Natural clustering and modular growth patterns",
      "aether:origin": "core"
    },
    {
      "@id": "technique:grid_based_precision",
      "@type": "skill:Technique",
      "rdfs:label": "Grid-based precision with dramatic negative space",
      "aether:origin": "core"
    },
    {
      "@id": "technique:spatial_orchestration",
      "@type": "skill:Technique",
      "rdfs:label": "Expert spatial orchestration",
      "aether:origin": "core"
    },
    {
      "@id": "technique:precision_alignment",
      "@type": "skill:Technique",
      "rdfs:label": "Every alignment the work of countless refinements",
      "aether:origin": "core"
    },
    {
      "@id": "technique:meditation_practice_care",
      "@type": "skill:Technique",
      "rdfs:label": "Each composition balanced with the care of meditation practice",
      "aether:origin": "core"
    }
  ]
}