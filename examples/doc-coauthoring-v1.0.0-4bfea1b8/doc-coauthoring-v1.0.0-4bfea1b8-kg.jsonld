      "aether:origin": "core"
    },
    {
      "@id": "antipattern:proceeding_without_context",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Proceeding without sufficient context gathering",
      "aether:origin": "core"
    }
  ]
