        "technique:surgical_editing"
      ]
    },
    {
      "@id": "concept:collaborative_workflow",
      "@type": "skill:Concept",
      "rdfs:label": "Collaborative Document Creation Workflow",
      "aether:origin": "core",
      "skill:contains": [
        "concept:three_stage_workflow",
        "concept:co_authoring"
      ],
      "skill:rules": [
        "rule:offer_workflow_on_triggers",
        "rule:explain_three_stages",
        "rule:allow_freeform_decline"
      ],
      "skill:techniques": [
        "technique:active_guidance",
        "technique:structured_progression"
      ]
    },
    {
      "@id": "concept:three_stage_workflow",
      "@type": "skill:Concept",
      "rdfs:label": "Three Stage Workflow",
      "aether:origin": "core",
      "skill:contains": [
        "concept:context_gathering",
        "concept:refinement_structure",
        "concept:reader_testing"
      ],
      "skill:rules": [
        "rule:proceed_sequentially",
        "rule:complete_stage_before_transition"
      ]
    },
    {
      "@id": "concept:context_gathering",
      "@type": "skill:Concept",
      "rdfs:label": "Context Gathering Stage",
      "aether:origin": "core",
      "skill:rules": [
        "rule:ask_initial_questions",
        "rule:encourage_info_dumping",
        "rule:ask_clarifying_questions",
        "rule:check_for_integrations"
      ],
      "skill:techniques": [
        "technique:meta_context_questions",
        "technique:info_dumping",
        "technique:clarifying_questions",
        "technique:integration_usage"
      ],
      "skill:avoids": [
        "antipattern:proceeding_without_context"
      ]
    },
    {
      "@id": "concept:refinement_structure",
      "@type": "skill:Concept",
      "rdfs:label": "Refinement & Structure Stage",
      "aether:origin": "core",
      "skill:rules": [
        "rule:build_section_by_section",
        "rule:start_with_unknowns",
        "rule:use_brainstorm_curate_draft"
      ],
      "skill:techniques": [
        "technique:section_by_section_building",
        "technique:brainstorm_curate_draft",
        "technique:surgical_editing"
      ],
      "skill:requires": [
        "concept:context_gathering"
      ]
    },
    {
      "@id": "concept:reader_testing",
      "@type": "skill:Concept",
      "rdfs:label": "Reader Testing Stage",
      "aether:origin": "core",
      "skill:rules": [
        "rule:test_with_fresh_claude"
      ],
      "skill:techniques": [
        "technique:reader_testing",
        "technique:blind_spot_detection"
      ]
    },
    {
      "@id": "concept:trigger_conditions",
      "@type": "skill:Concept",
      "rdfs:label": "Workflow Trigger Conditions",
      "aether:origin": "core",
      "skill:contains": [
        "concept:documentation_mentions",
        "concept:document_types",
        "concept:substantial_writing_tasks"
      ],
      "skill:rules": [
        "rule:offer_workflow_on_triggers"
      ]
    },
    {
      "@id": "concept:documentation_mentions",
      "@type": "skill:Concept",
      "rdfs:label": "Documentation Writing Mentions",
      "aether:origin": "core",
      "skill:contains": [
        "tool:write_doc",
        "tool:draft_proposal",
        "tool:create_spec",
        "tool:write_up"
      ]
    },
    {
      "@id": "concept:document_types",
      "@type": "skill:Concept",
      "rdfs:label": "Specific Document Types",
      "aether:origin": "core",
      "skill:contains": [
        "tool:prd",
        "tool:design_doc",
        "tool:decision_doc",
        "tool:rfc"
      ]
    },
    {
      "@id": "concept:integration_handling",
      "@type": "skill:Concept",
      "rdfs:label": "Integration Handling",
      "aether:origin": "core",
      "skill:rules": [
        "rule:check_for_integrations",
        "rule:suggest_connectors_if_unavailable",
        "rule:use_integrations_for_context"
      ],
      "skill:techniques": [
        "technique:integration_usage",
        "technique:connector_suggestion"
      ]
    },
    {
      "@id": "concept:image_handling",
      "@type": "skill:Concept",
      "rdfs:label": "Image Alt-Text Handling",
      "aether:origin": "core",
      "skill:rules": [
        "rule:check_images_for_alt_text",
        "rule:explain_claude_image_limitation",
        "rule:offer_alt_text_generation"
      ]
    },
    {
      "@id": "rule:offer_workflow_on_triggers",
      "@type": "skill:Rule",
      "rdfs:label": "Offer structured workflow when trigger conditions are met",
      "aether:origin": "core"
    },
    {
      "@id": "rule:explain_three_stages",
      "@type": "skill:Rule",
      "rdfs:label": "Explain the three stages: Context Gathering, Refinement & Structure, Reader Testing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:allow_freeform_decline",
      "@type": "skill:Rule",
      "rdfs:label": "If user declines workflow, work freeform",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ask_initial_questions",
      "@type": "skill:Rule",
      "rdfs:label": "Ask meta-context questions: doc type, audience, impact, template, constraints",
      "aether:origin": "core"
    },
    {
      "@id": "rule:encourage_info_dumping",
      "@type": "skill:Rule",
      "rdfs:label": "Encourage user to dump all context without organizing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ask_clarifying_questions",
      "@type": "skill:Rule",
      "rdfs:label": "Generate 5-10 numbered clarifying questions based on context gaps",
      "aether:origin": "core"
    },
    {
      "@id": "rule:check_for_integrations",
      "@type": "skill:Rule",
      "rdfs:label": "Check for available integrations and mention their use for context gathering",
      "aether:origin": "core"
    },
    {
      "@id": "rule:suggest_connectors_if_unavailable",
      "@type": "skill:Rule",
      "rdfs:label": "Suggest enabling connectors in Claude settings if integrations unavailable",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_integrations_for_context",
      "@type": "skill:Rule",
      "rdfs:label": "Use appropriate integrations to fetch content from shared documents and channels",
      "aether:origin": "core"
    },
    {
      "@id": "rule:check_images_for_alt_text",
      "@type": "skill:Rule",
      "rdfs:label": "Check for images without alt-text in existing documents",
      "aether:origin": "core"
    },
    {
      "@id": "rule:explain_claude_image_limitation",
      "@type": "skill:Rule",
      "rdfs:label": "Explain that Claude won't be able to see images without alt-text",
      "aether:origin": "core"
    },
    {
      "@id": "rule:offer_alt_text_generation",
      "@type": "skill:Rule",
      "rdfs:label": "Offer to generate alt-text if user pastes images into chat",
      "aether:origin": "core"
    },
    {
      "@id": "rule:build_section_by_section",
      "@type": "skill:Rule",
      "rdfs:label": "Build document section by section through brainstorming, curation, and refinement",
      "aether:origin": "core"
    },
    {
      "@id": "rule:start_with_unknowns",
      "@type": "skill:Rule",
      "rdfs:label": "Start with section that has the most unknowns",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_brainstorm_curate_draft",
      "@type": "skill:Rule",
      "rdfs:label": "For each section: ask questions, brainstorm 5-20 options, curate, draft, refine",
      "aether:origin": "core"
    },
    {
      "@id": "rule:test_with_fresh_claude",
      "@type": "skill:Rule",
      "rdfs:label": "Test document with fresh Claude instance to catch blind spots",
      "aether:origin": "core"
    },
    {
      "@id": "rule:proceed_sequentially",
      "@type": "skill:Rule",
      "rdfs:label": "Proceed through workflow stages sequentially",
      "aether:origin": "core"
    },
    {
      "@id": "rule:complete_stage_before_transition",
      "@type": "skill:Rule",
      "rdfs:label": "Complete each stage before transitioning to next",
      "aether:origin": "core"
    },
    {
      "@id": "technique:active_guidance",
      "@type": "skill:Technique",
      "rdfs:label": "Act as active guide walking users through workflow",
      "aether:origin": "core"
    },
    {
      "@id": "technique:structured_progression",
      "@type": "skill:Technique",
      "rdfs:label": "Follow structured progression through defined stages",
      "aether:origin": "core"
    },
    {
      "@id": "technique:meta_context_questions",
      "@type": "skill:Technique",
      "rdfs:label": "Ask meta-context questions about document type, audience, impact",
      "aether:origin": "core"
    },
    {
      "@id": "technique:info_dumping",
      "@type": "skill:Technique",
      "rdfs:label": "Allow stream-of-consciousness information dumping",
      "aether:origin": "core"
    },
    {
      "@id": "technique:clarifying_questions",
      "@type": "skill:Technique",
      "rdfs:label": "Generate numbered clarifying questions based on context gaps",
      "aether:origin": "core"
    },
    {
      "@id": "technique:integration_usage",
      "@type": "skill:Technique",
      "rdfs:label": "Use integrations to pull context from messaging apps and document storage",
      "aether:origin": "core"
    },
    {
      "@id": "technique:connector_suggestion",
      "@type": "skill:Technique",
      "rdfs:label": "Suggest enabling connectors when integrations unavailable",
      "aether:origin": "core"
    },
    {
      "@id": "technique:shorthand_acceptance",
      "@type": "skill:Technique",
      "rdfs:label": "Accept shorthand answers and flexible input methods",
      "aether:origin": "core"
    },
    {
      "@id": "technique:flexible_input_methods",
      "@type": "skill:Technique",
      "rdfs:label": "Offer multiple ways to provide context: dumping, linking, pasting",
      "aether:origin": "core"
    },
    {
      "@id": "technique:section_by_section_building",
      "@type": "skill:Technique",
      "rdfs:label": "Build document section by section with iterative refinement",
      "aether:origin": "core"
    },
    {
      "@id": "technique:brainstorm_curate_draft",
      "@type": "skill:Technique",
      "rdfs:label": "Brainstorm 5-20 options, let user curate, then draft section",
      "aether:origin": "core"
    },
    {
      "@id": "technique:surgical_editing",
      "@type": "skill:Technique",
      "rdfs:label": "Refine sections through precise surgical edits",
      "aether:origin": "core"
    },
    {
      "@id": "technique:template_following",
      "@type": "skill:Technique",
      "rdfs:label": "Follow provided templates or format requirements",
      "aether:origin": "core"
    },
    {
      "@id": "technique:reader_testing",
      "@type": "skill:Technique",
      "rdfs:label": "Test document with fresh Claude instance to simulate reader experience",
      "aether:origin": "core"
    },
    {
      "@id": "technique:blind_spot_detection",
      "@type": "skill:Technique",
      "rdfs:label": "Use reader testing to catch blind spots before others read document",
      "aether:origin": "core"
    },
    {
      "@id": "technique:context_assessment",
      "@type": "skill:Technique",
      "rdfs:label": "Assess context completeness and identify gaps",
      "aether:origin": "core"
    },
    {
      "@id": "technique:gap_identification",
      "@type": "skill:Technique",
      "rdfs:label": "Track what's learned and what's still unclear during context gathering",
      "aether:origin": "core"
    },
