      "aether:origin": "core"
    },
    {
      "@id": "tool:slack",
      "@type": "skill:Tool",
      "rdfs:label": "Slack",
      "aether:origin": "core"
    },
    {
      "@id": "tool:teams",
      "@type": "skill:Tool",
      "rdfs:label": "Teams",
      "aether:origin": "core"
    },
    {
      "@id": "tool:google_drive",
      "@type": "skill:Tool",
      "rdfs:label": "Google Drive",
      "aether:origin": "core"
    },
    {
      "@id": "tool:sharepoint",
      "@type": "skill:Tool",
