      "skill:enables": [
        "technique:context_assessment",
        "technique:reader_testing"
      ]
    },
    {
      "@id": "trait:methodical",
      "@type": "skill:Trait",
      "rdfs:label": "Methodical",
      "aether:origin": "core",
      "skill:enables": [
        "concept:stage_progression",
        "technique:section_by_section_building"
      ]
    },
    {
      "@id": "trait:supportive",
      "@type": "skill:Trait",
      "rdfs:label": "Supportive",
