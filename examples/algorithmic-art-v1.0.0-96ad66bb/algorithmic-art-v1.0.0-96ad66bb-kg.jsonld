      "rdfs:label": "Two step process: Algorithmic Philosophy Creation then p5.js Expression",
      "aether:origin": "core"
    },
    {
      "@id": "rule:algorithmic_not_static",
      "@type": "skill:Rule",
      "rdfs:label": "Create algorithmic philosophy not static images or templates",
