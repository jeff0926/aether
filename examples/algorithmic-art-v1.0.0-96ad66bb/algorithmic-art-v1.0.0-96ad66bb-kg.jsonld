      "skill:avoids": [
        "antipattern:static_images",
        "antipattern:templates"
      ]
    },
    {
      "@id": "rule:four_to_six_paragraphs",
      "@type": "skill:Rule",
      "rdfs:label": "Philosophy must be 4-6 paragraphs concise but complete",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_redundancy",
      "@type": "skill:Rule",
      "rdfs:label": "Avoid redundancy - each algorithmic aspect mentioned once",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:repeating_concepts"
      ]
    },
    {
      "@id": "rule:emphasize_craftsmanship_repeatedly",
