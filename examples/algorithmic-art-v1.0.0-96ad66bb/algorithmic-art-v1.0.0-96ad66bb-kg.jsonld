      "skill:requires": [
        "technique:craftsmanship_phrases"
      ]
    },
    {
      "@id": "rule:leave_creative_space",
      "@type": "skill:Rule",
      "rdfs:label": "Leave creative space for implementation choices at high craftsmanship level",
      "aether:origin": "core"
    },
    {
      "@id": "rule:appear_countless_hours_development",
      "@type": "skill:Rule",
      "rdfs:label": "Algorithm should appear as though it took countless hours to develop",
      "aether:origin": "core"
    },
    {
      "@id": "rule:master_level_implementation",
      "@type": "skill:Rule",
      "rdfs:label": "Come from someone at the absolute top of their field",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ninety_percent_algorithmic",
      "@type": "skill:Rule",
      "rdfs:label": "p5.js sketches are 90% algorithmic generation, 10% essential parameters",
      "aether:origin": "core"
    },
    {
      "@id": "rule:beauty_lives_in_process",
      "@type": "skill:Rule",
      "rdfs:label": "Beauty lives in the process, not the final frame",
      "aether:origin": "core"
    },
    {
      "@id": "rule:each_run_unique",
      "@type": "skill:Rule",
      "rdfs:label": "Each run produces unique beauty - process over product",
