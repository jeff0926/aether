        "tool:react",
        "tool:typescript",
        "tool:vite",
        "tool:parcel",
        "tool:tailwind",
        "tool:shadcn"
      ]
    },
    {
      "@id": "rule:follow_five_step_process",
      "@type": "skill:Rule",
      "rdfs:label": "Follow five-step artifact building process",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_init_script",
      "@type": "skill:Rule",
      "rdfs:label": "Initialize projects using scripts/init-artifact.sh",
      "aether:origin": "core"
    },
    {
      "@id": "rule:edit_generated_files",
      "@type": "skill:Rule",
      "rdfs:label": "Develop artifact by editing generated code",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_bundle_script",
      "@type": "skill:Rule",
      "rdfs:label": "Bundle using scripts/bundle-artifact.sh",
      "aether:origin": "core"
    },
    {
      "@id": "rule:share_bundled_html",
      "@type": "skill:Rule",
      "rdfs:label": "Display bundled HTML artifact to user",
      "aether:origin": "core"
    },
    {
      "@id": "rule:testing_optional",
      "@type": "skill:Rule",
      "rdfs:label": "Testing is optional and only when necessary",
      "aether:origin": "core"
    },
    {
      "@id": "rule:test_after_presentation",
      "@type": "skill:Rule",
      "rdfs:label": "Test after presenting artifact to avoid latency",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_ai_slop_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "Avoid AI slop design patterns",
      "aether:origin": "core",
      "skill:avoids": "antipattern:ai_slop"
    },
    {
      "@id": "rule:use_prescribed_stack",
      "@type": "skill:Rule",
      "rdfs:label": "Use React 18 + TypeScript + Vite + Parcel + Tailwind CSS + shadcn/ui stack",
      "aether:origin": "core"
    },
    {
      "@id": "rule:require_root_index_html",
      "@type": "skill:Rule",
      "rdfs:label": "Project must have index.html in root directory for bundling",
      "aether:origin": "core"
    },
    {
      "@id": "rule:bundle_to_single_html",
      "@type": "skill:Rule",
      "rdfs:label": "Bundle all code into single HTML file",
      "aether:origin": "core"
    },
    {
      "@id": "rule:verify_all_dependencies",
      "@type": "skill:Rule",
      "rdfs:label": "Ensure all dependencies are properly configured",
      "aether:origin": "core"
    },
    {
      "@id": "rule:production_ready_standards",
      "@type": "skill:Rule",
      "rdfs:label": "Build production-ready artifacts with technical precision",
      "aether:origin": "core"
    },
    {
      "@id": "rule:take_strong_stances",
      "@type": "skill:Rule",
      "rdfs:label": "Take strong stances against poor design patterns",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_structured_steps",
      "@type": "skill:Rule",
      "rdfs:label": "Follow structured development steps systematically",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:ai_slop",
      "@type": "skill:AntiPattern",
      "rdfs:label": "AI slop design patterns",
      "aether:origin": "core",
      "skill:contains": [
        "antipattern:excessive_centered_layouts",
        "antipattern:purple_gradients",
        "antipattern:uniform_rounded_corners",
        "antipattern:inter_font"
      ]
    },
    {
      "@id": "antipattern:excessive_centered_layouts",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Excessive centered layouts",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:purple_gradients",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Purple gradients",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:uniform_rounded_corners",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Uniform rounded corners",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:inter_font",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Inter font usage",
      "aether:origin": "core"
