      "skill:contains": [
        "concept:skill_creation_process",
        "concept:progressive_disclosure"
      ],
      "skill:techniques": [
        "technique:three_level_loading",
        "technique:interview_and_research"
      ]
    },
    {
      "@id": "rule:start_with_intent",
      "@type": "skill:Rule",
      "rdfs:label": "Start by understanding the user's intent",
      "aether:origin": "core"
    },
    {
      "@id": "rule:understand_what_skill_enables",
      "@type": "skill:Rule",
      "rdfs:label": "What should this skill enable Claude to do?",
      "aether:origin": "core"
    },
    {
      "@id": "rule:define_trigger_contexts",
      "@type": "skill:Rule",
      "rdfs:label": "When should this skill trigger? (what user phrases/contexts)",
      "aether:origin": "core"
    },
    {
      "@id": "rule:specify_output_format",
      "@type": "skill:Rule",
      "rdfs:label": "What's the expected output format?",
      "aether:origin": "core"
    },
    {
      "@id": "rule:write_test_cases_before_implementation",
      "@type": "skill:Rule",
      "rdfs:label": "Wait to write test prompts until you've got the interview part ironed out",
      "aether:origin": "core"
    },
    {
      "@id": "rule:adapt_technical_language",
      "@type": "skill:Rule",
      "rdfs:label": "Pay attention to context cues to understand how to phrase communication",
      "aether:origin": "core"
    },
    {
      "@id": "rule:pay_attention_to_context_cues",
      "@type": "skill:Rule",
      "rdfs:label": "Evaluation and benchmark are OK, JSON and assertion need user cues",
      "aether:origin": "core"
    },
    {
      "@id": "rule:pushy_skill_descriptions",
      "@type": "skill:Rule",
      "rdfs:label": "Make skill descriptions pushy to combat undertriggering",
      "aether:origin": "core"
    },
    {
      "@id": "rule:yaml_frontmatter_required",
      "@type": "skill:Rule",
      "rdfs:label": "SKILL.md requires YAML frontmatter with name and description",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:assume_technical_knowledge",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Assuming user technical knowledge without context cues",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:rigid_communication_style",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Using rigid communication style regardless of user expertise",
      "aether:origin": "core"
    },
    {
      "@id": "technique:user_intent_capture",
      "@type": "skill:Technique",
      "rdfs:label": "Capture user intent through systematic questioning",
      "aether:origin": "core"
    },
    {
      "@id": "technique:extract_from_conversation_history",
      "@type": "skill:Technique",
      "rdfs:label": "Extract answers from conversation history first",
      "aether:origin": "core"
    },
    {
      "@id": "technique:proactive_edge_case_questioning",
      "@type": "skill:Technique",
      "rdfs:label": "Proactively ask about edge cases, input/output formats, example files",
      "aether:origin": "core"
    },
    {
      "@id": "technique:interview_and_research",
      "@type": "skill:Technique",
      "rdfs:label": "Interview user and research via MCPs if available",
      "aether:origin": "core"
    },
    {
      "@id": "technique:draft_test_iterate",
      "@type": "skill:Technique",
      "rdfs:label": "Write draft, create test prompts, run evaluations, iterate",
      "aether:origin": "core"
    },
    {
      "@id": "technique:background_evaluation",
      "@type": "skill:Technique",
      "rdfs:label": "Draft quantitative evals while runs happen in background",
      "aether:origin": "core"
    },
    {
      "@id": "technique:eval_viewer_script",
      "@type": "skill:Technique",
      "rdfs:label": "Use eval-viewer/generate_review.py to show results",
      "aether:origin": "core"
    },
    {
      "@id": "technique:iterative_improvement",
      "@type": "skill:Technique",
      "rdfs:label": "Rewrite skill based on evaluation feedback and repeat until satisfied",
      "aether:origin": "core"
    },
    {
      "@id": "technique:scale_expansion",
      "@type": "skill:Technique",
      "rdfs:label": "Expand test set and try again at larger scale",
      "aether:origin": "core"
    },
    {
      "@id": "technique:flexible_entry_points",
      "@type": "skill:Technique",
      "rdfs:label": "Figure out where user is in process and jump in to help",
      "aether:origin": "core"
    },
    {
      "@id": "technique:flexible_workflow",
      "@type": "skill:Technique",
      "rdfs:label": "Be flexible if user says they don't need evaluations, just vibe",
      "aether:origin": "core"
    },
    {
      "@id": "technique:repeat_until_satisfied",
      "@type": "skill:Technique",
      "rdfs:label": "Repeat evaluation and improvement cycle until satisfied",
      "aether:origin": "core"
    },
    {
      "@id": "technique:context_aware_communication",
      "@type": "skill:Technique",
      "rdfs:label": "Adapt communication to user familiarity with coding jargon",
      "aether:origin": "core"
    },
    {
      "@id": "technique:progressive_disclosure",
      "@type": "skill:Technique",
      "rdfs:label": "Three-level loading system for skills",
      "aether:origin": "core"
    },
    {
      "@id": "technique:three_level_loading",
      "@type": "skill:Technique",
      "rdfs:label": "Metadata, SKILL.md body, Bundled resources loading levels",
      "aether:origin": "core"
    },
    {
      "@id": "concept:test_prompt_creation",
      "@type": "skill:Concept",
      "rdfs:label": "Test Prompt Creation",
      "aether:origin": "core",
      "skill:rules": [
        "rule:objective_skills_need_tests",
        "rule:subjective_skills_often_dont_need_tests"
      ]
    },
    {
      "@id": "rule:objective_skills_need_tests",
      "@type": "skill:Rule",
      "rdfs:label": "Skills with objectively verifiable outputs benefit from test cases",
      "aether:origin": "core"
    },
    {
      "@id": "rule:subjective_skills_often_dont_need_tests",
      "@type": "skill:Rule",
      "rdfs:label": "Skills with subjective outputs often don't need test cases",
      "aether:origin": "core"
    },
