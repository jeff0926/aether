        "technique:ask_for_choice",
        "technique:wait_for_selection",
        "technique:apply_theme"
      ]
    },
    {
      "@id": "technique:show_theme_showcase",
      "@type": "skill:Technique",
      "rdfs:label": "Display theme-showcase.pdf for visual selection",
      "aether:origin": "core",
      "skill:requires": [
        "tool:theme_showcase_pdf"
      ],
      "skill:rules": [
        "rule:no_modifications_to_showcase"
      ]
    },
    {
      "@id": "technique:ask_for_choice",
      "@type": "skill:Technique",
      "rdfs:label": "Ask which theme to apply to the deck",
      "aether:origin": "core"
    },
    {
      "@id": "technique:wait_for_selection",
      "@type": "skill:Technique",
      "rdfs:label": "Get explicit confirmation about chosen theme",
      "aether:origin": "core",
      "skill:rules": [
        "rule:get_explicit_confirmation"
      ]
    },
    {
      "@id": "technique:apply_theme",
      "@type": "skill:Technique",
      "rdfs:label": "Apply selected theme's colors and fonts",
      "aether:origin": "core",
      "skill:contains": [
        "technique:read_theme_file",
        "technique:apply_colors_fonts",
        "technique:ensure_contrast",
        "technique:maintain_identity"
      ]
    },
    {
      "@id": "technique:read_theme_file",
      "@type": "skill:Technique",
      "rdfs:label": "Read corresponding theme file from themes/ directory",
      "aether:origin": "core",
      "skill:requires": [
        "tool:themes_directory"
      ]
    },
    {
      "@id": "technique:apply_colors_fonts",
      "@type": "skill:Technique",
      "rdfs:label": "Apply specified colors and fonts consistently",
      "aether:origin": "core",
      "skill:rules": [
        "rule:apply_consistently_throughout"
      ]
    },
    {
      "@id": "technique:ensure_contrast",
      "@type": "skill:Technique",
      "rdfs:label": "Ensure proper contrast and readability",
      "aether:origin": "core",
      "skill:rules": [
        "rule:ensure_proper_contrast",
        "rule:ensure_proper_readability"
      ]
    },
    {
      "@id": "technique:maintain_identity",
      "@type": "skill:Technique",
      "rdfs:label": "Maintain theme's visual identity across all slides",
      "aether:origin": "core",
      "skill:rules": [
        "rule:maintain_visual_identity"
      ]
    },
    {
      "@id": "technique:custom_theme_creation",
      "@type": "skill:Technique",
      "rdfs:label": "Create custom theme when existing themes don't work",
      "aether:origin": "core",
      "skill:contains": [
        "technique:generate_custom_theme",
        "technique:show_for_review",
        "technique:apply_after_verification"
      ]
    },
    {
      "@id": "technique:generate_custom_theme",
      "@type": "skill:Technique",
      "rdfs:label": "Generate new theme based on provided inputs",
      "aether:origin": "core",
      "skill:rules": [
        "rule:give_descriptive_name",
        "rule:use_basic_description_inputs"
      ]
    },
    {
      "@id": "technique:show_for_review",
      "@type": "skill:Technique",
      "rdfs:label": "Show generated theme for review and verification",
      "aether:origin": "core"
    },
    {
      "@id": "technique:apply_after_verification",
      "@type": "skill:Technique",
      "rdfs:label": "Apply theme after verification following standard process",
      "aether:origin": "core",
      "skill:requires": [
        "technique:four_step_application_process"
      ]
    },
    {
      "@id": "rule:no_modifications_to_showcase",
      "@type": "skill:Rule",
      "rdfs:label": "Do not make any modifications to theme-showcase.pdf; simply show for viewing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:get_explicit_confirmation",
      "@type": "skill:Rule",
      "rdfs:label": "Get explicit confirmation about the chosen theme",
      "aether:origin": "core"
    },
    {
      "@id": "rule:apply_consistently_throughout",
      "@type": "skill:Rule",
      "rdfs:label": "Apply specified colors and fonts consistently throughout the deck",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ensure_proper_contrast",
      "@type": "skill:Rule",
      "rdfs:label": "Ensure proper contrast and readability",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ensure_proper_readability",
      "@type": "skill:Rule",
      "rdfs:label": "Ensure proper readability",
      "aether:origin": "core"
    },
    {
      "@id": "rule:maintain_visual_identity",
      "@type": "skill:Rule",
      "rdfs:label": "Maintain the theme's visual identity across all slides",
      "aether:origin": "core"
    },
    {
      "@id": "rule:follow_structured_workflow",
      "@type": "skill:Rule",
      "rdfs:label": "Follow systematic four-step application process",
      "aether:origin": "core"
    },
    {
      "@id": "rule:give_descriptive_name",
      "@type": "skill:Rule",
      "rdfs:label": "Give the custom theme a descriptive name representing font/color combinations",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_basic_description_inputs",
      "@type": "skill:Rule",
      "rdfs:label": "Use any basic description provided to choose appropriate colors/fonts",
      "aether:origin": "core"
    }
