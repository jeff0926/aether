      "aether:origin": "core"
    },
    {
      "@id": "rule:async_implementation",
      "@type": "skill:Rule",
      "rdfs:label": "Use async/await for I/O operations with proper error handling",
      "aether:origin": "core"
    },
    {
      "@id": "rule:annotation_usage",
      "@type": "skill:Rule",
      "rdfs:label": "Use readOnlyHint, destructiveHint, idempotentHint, openWorldHint annotations",
      "aether:origin": "core"
    },
