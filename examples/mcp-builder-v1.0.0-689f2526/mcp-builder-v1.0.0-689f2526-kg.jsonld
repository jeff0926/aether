    {
      "@id": "rule:input_schema_requirements",
      "@type": "skill:Rule",
      "rdfs:label": "Use Zod (TypeScript) or Pydantic (Python) with constraints and clear descriptions",
      "aether:origin": "core"
    },
    {
      "@id": "rule:output_schema_definition",
