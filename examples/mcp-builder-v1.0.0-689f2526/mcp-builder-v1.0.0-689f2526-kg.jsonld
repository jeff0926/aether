      "@id": "rule:typescript_preference",
      "@type": "skill:Rule",
      "rdfs:label": "TypeScript preferred for high-quality SDK support and good compatibility in execution environments",
      "aether:origin": "core"
    },
    {
      "@id": "rule:transport_selection",
      "@type": "skill:Rule",
      "rdfs:label": "Streamable HTTP for remote servers using stateless JSON, stdio for local servers",
      "aether:origin": "core"
    },
