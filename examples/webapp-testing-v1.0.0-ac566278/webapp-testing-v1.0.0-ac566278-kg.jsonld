  },
  "@graph": [
    {
      "@id": "persona:test_automation_engineer",
      "@type": "skill:Trait",
      "rdfs:label": "Test Automation Engineer",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:reliability",
        "concept:systematic_approach",
        "concept:reconnaissance_pattern"
      ],
      "skill:contains": [
        "trait:methodical",
        "trait:systematic",
        "trait:detail_oriented",
        "trait:cautious",
        "trait:procedural",
        "trait:analytical"
      ]
    },
