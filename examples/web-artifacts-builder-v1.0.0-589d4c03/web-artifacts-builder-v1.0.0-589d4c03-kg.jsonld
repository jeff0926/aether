      "@id": "concept:configuration_completeness",
      "@type": "skill:Concept",
      "rdfs:label": "Configuration Completeness",
      "aether:origin": "core",
      "skill:requires": [
        "tool:react",
        "tool:typescript",
        "tool:vite",
        "tool:tailwind",
        "tool:shadcn",
        "tool:parcel"
      ]
    },
    {
      "@id": "rule:avoid_ai_slop",
      "@type": "skill:Rule",
      "rdfs:label": "Avoid excessive centered layouts, purple gradients, uniform rounded corners, and Inter font",
      "aether:origin": "core",
      "skill:contradicts": [
        "antipattern:ai_slop"
      ]
    },
    {
      "@id": "rule:complete_configuration",
      "@type": "skill:Rule",
      "rdfs:label": "Ensure fully configured project with all dependencies and components pre-installed",
      "aether:origin": "core"
    },
    {
      "@id": "rule:single_html_output",
      "@type": "skill:Rule",
      "rdfs:label": "Bundle all code into a single HTML file for artifact sharing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:index_html_requirement",
      "@type": "skill:Rule",
      "rdfs:label": "Project must have an index.html in the root directory for bundling",
      "aether:origin": "core"
    },
    {
      "@id": "rule:optional_testing",
      "@type": "skill:Rule",
      "rdfs:label": "Testing is optional and should be performed after presenting artifact to avoid latency",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:ai_slop",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Excessive centered layouts, purple gradients, uniform rounded corners, and Inter font",
      "aether:origin": "core"
    },
    {
      "@id": "technique:five_step_process",
      "@type": "skill:Technique",
      "rdfs:label": "Five Step Process: Initialize, Develop, Bundle, Display, Test",
      "aether:origin": "core",
      "skill:contains": [
        "technique:project_initialization",
        "technique:development_workflow",
        "technique:single_html_bundling",
        "technique:artifact_sharing",
        "technique:optional_testing"
      ]
    },
    {
      "@id": "technique:project_initialization",
      "@type": "skill:Technique",
      "rdfs:label": "Initialize project using init-artifact.sh script",
      "aether:origin": "core",
      "skill:requires": [
        "tool:init_script"
      ]
    },
    {
      "@id": "technique:development_workflow",
      "@type": "skill:Technique",
      "rdfs:label": "Develop artifact by editing generated code",
      "aether:origin": "core"
    },
    {
      "@id": "technique:single_html_bundling",
      "@type": "skill:Technique",
      "rdfs:label": "Bundle using bundle-artifact.sh script to create single HTML file",
      "aether:origin": "core",
      "skill:requires": [
        "tool:bundle_script",
        "tool:parcel"
      ],
      "skill:enables": [
        "technique:asset_inlining"
      ]
    },
    {
      "@id": "technique:asset_inlining",
      "@type": "skill:Technique",
      "rdfs:label": "Inline all JavaScript, CSS, and dependencies into single HTML",
      "aether:origin": "core",
      "skill:requires": [
        "tool:html_inline"
      ]
    },
    {
      "@id": "technique:artifact_sharing",
      "@type": "skill:Technique",
      "rdfs:label": "Share bundled HTML file in conversation for artifact viewing",
      "aether:origin": "core"
    },
    {
      "@id": "technique:optional_testing",
      "@type": "skill:Technique",
      "rdfs:label": "Test after presenting artifact using available tools to avoid upfront latency",
      "aether:origin": "core"
    },
    {
      "@id": "technique:script_automation",
      "@type": "skill:Technique",
      "rdfs:label": "Use automated scripts for initialization and bundling",
      "aether:origin": "core",
      "skill:requires": [
        "tool:init_script",
        "tool:bundle_script"
      ]
    },
