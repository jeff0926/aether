        "concept:visual_consistency",
        "concept:color_accuracy"
      ],
      "skill:contains": [
        "trait:precise",
        "trait:systematic",
        "trait:detail_oriented",
        "trait:perfectionist",
        "trait:conservative"
      ]
    },
    {
