    {
      "@id": "concept:claude_defaults",
      "@type": "skill:Concept",
      "rdfs:label": "Claude Default Configuration",
      "aether:origin": "core",
      "skill:rules": [
        "rule:use_claude_opus_4_6",
        "rule:default_adaptive_thinking",
        "rule:default_streaming"
      ]
    },
    {
      "@id": "rule:use_claude_opus_4_6",
      "@type": "skill:Rule",
      "rdfs:label": "Use Claude Opus 4.6 with exact model string claude-opus-4-6",
      "aether:origin": "core"
    },
    {
      "@id": "rule:default_adaptive_thinking",
      "@type": "skill:Rule",
      "rdfs:label": "Default to adaptive thinking for anything remotely complicated",
      "aether:origin": "core"
    },
    {
      "@id": "rule:default_streaming",
      "@type": "skill:Rule",
      "rdfs:label": "Default to streaming for long input, long output, or high max_tokens",
      "aether:origin": "core"
    },
    {
      "@id": "concept:language_detection",
      "@type": "skill:Concept",
      "rdfs:label": "Programming Language Detection",
      "aether:origin": "core",
      "skill:rules": [
        "rule:look_at_project_files",
        "rule:handle_multiple_languages",
        "rule:handle_undetectable_language",
        "rule:handle_unsupported_language"
      ],
      "skill:techniques": [
        "technique:file_pattern_matching",
        "technique:ask_user_question_fallback"
      ]
    },
    {
      "@id": "rule:look_at_project_files",
      "@type": "skill:Rule",
      "rdfs:label": "Look at project files to infer the language before reading code examples",
      "aether:origin": "core",
      "skill:enables": [
        "technique:file_pattern_matching"
      ]
    },
    {
      "@id": "rule:handle_multiple_languages",
      "@type": "skill:Rule",
      "rdfs:label": "If multiple languages detected, check which relates to user's current question or ask for clarification",
      "aether:origin": "core"
    },
    {
      "@id": "rule:handle_undetectable_language",
      "@type": "skill:Rule",
      "rdfs:label": "If language can't be inferred, use AskUserQuestion with options or default to Python",
      "aether:origin": "core"
    },
    {
      "@id": "rule:handle_unsupported_language",
      "@type": "skill:Rule",
      "rdfs:label": "If unsupported language detected, suggest cURL examples and note community SDKs may exist",
      "aether:origin": "core"
    },
    {
      "@id": "technique:file_pattern_matching",
      "@type": "skill:Technique",
      "rdfs:label": "File Pattern Matching for Language Detection",
      "aether:origin": "core",
      "skill:contains": [
        "rule:python_patterns",
        "rule:typescript_patterns",
        "rule:java_patterns",
        "rule:go_patterns",
        "rule:ruby_patterns",
        "rule:csharp_patterns",
        "rule:php_patterns"
      ]
    },
    {
      "@id": "rule:python_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.py, requirements.txt, pyproject.toml, setup.py, Pipfile indicates Python",
      "aether:origin": "core"
    },
    {
      "@id": "rule:typescript_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.ts, *.tsx, package.json, tsconfig.json indicates TypeScript",
      "aether:origin": "core"
    },
    {
      "@id": "rule:java_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.java, pom.xml, build.gradle indicates Java",
      "aether:origin": "core"
    },
    {
      "@id": "rule:kotlin_uses_java_sdk",
      "@type": "skill:Rule",
      "rdfs:label": "Kotlin and Scala use the Java SDK",
      "aether:origin": "core"
    },
    {
      "@id": "rule:go_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.go, go.mod indicates Go",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ruby_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.rb, Gemfile indicates Ruby",
      "aether:origin": "core"
    },
    {
      "@id": "rule:csharp_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.cs, *.csproj indicates C#",
      "aether:origin": "core"
    },
    {
      "@id": "rule:php_patterns",
      "@type": "skill:Rule",
      "rdfs:label": "*.php, composer.json indicates PHP",
      "aether:origin": "core"
    },
