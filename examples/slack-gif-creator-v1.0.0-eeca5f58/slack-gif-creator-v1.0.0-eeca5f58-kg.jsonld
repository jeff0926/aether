      ]
    },
    {
      "@id": "concept:shake_vibrate",
      "@type": "skill:Concept",
      "rdfs:label": "Shake/Vibrate Animation",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:oscillation_offset"
      ]
    },
    {
      "@id": "technique:oscillation_offset",
      "@type": "skill:Technique",
      "rdfs:label": "Offset object position with math.sin/cos oscillation",
      "aether:origin": "core"
    },
