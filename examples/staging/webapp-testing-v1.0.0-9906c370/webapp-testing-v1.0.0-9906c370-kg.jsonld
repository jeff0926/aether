      "@id": "technique:timeout_wait",
      "@type": "skill:Technique",
      "rdfs:label": "Timeout Wait",
      "aether:origin": "core"
    },
    {
      "@id": "rule:always_run_help_first",
      "@type": "skill:Rule",
      "rdfs:label": "Always run scripts with --help first to see usage",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:context_window_pollution"
      ]
    },
    {
      "@id": "rule:dont_read_source_until_necessary",
      "@type": "skill:Rule",
      "rdfs:label": "Do not read source until you try running the script first and find that a customized solution is absolutely necessary",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:context_window_pollution"
      ]
    },
    {
      "@id": "rule:use_scripts_as_black_boxes",
      "@type": "skill:Rule",
      "rdfs:label": "Use bundled scripts as black boxes - scripts exist to be called directly rather than ingested into context window",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:context_window_pollution"
      ]
    },
    {
      "@id": "rule:wait_for_networkidle",
      "@type": "skill:Rule",
      "rdfs:label": "Wait for page.wait_for_load_state('networkidle') on dynamic apps",
      "aether:origin": "core",
      "skill:contradicts": [
        "antipattern:inspect_dom_before_networkidle"
      ]
    },
    {
      "@id": "rule:wait_for_networkidle_before_inspection",
      "@type": "skill:Rule",
      "rdfs:label": "Wait for networkidle before DOM inspection",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:inspect_dom_before_networkidle"
      ]
    },
    {
      "@id": "rule:use_headless_mode",
      "@type": "skill:Rule",
      "rdfs:label": "Always launch chromium in headless mode",
      "aether:origin": "core"
    },
    {
      "@id": "rule:close_browser_when_done",
      "@type": "skill:Rule",
      "rdfs:label": "Always close the browser when done",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_descriptive_selectors",
      "@type": "skill:Rule",
      "rdfs:label": "Use descriptive selectors: text=, role=, CSS selectors, or IDs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:add_appropriate_waits",
      "@type": "skill:Rule",
      "rdfs:label": "Add appropriate waits: page.wait_for_selector() or page.wait_for_timeout()",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:context_window_pollution",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Context Window Pollution",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:inspect_dom_before_networkidle",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Inspect DOM before waiting for networkidle on dynamic apps",
      "aether:origin": "core"
    }
  ]
}