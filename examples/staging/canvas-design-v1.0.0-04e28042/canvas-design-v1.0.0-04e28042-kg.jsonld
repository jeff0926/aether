  },
  "@graph": [
    {
      "@id": "persona:aesthetic_philosopher",
      "@type": "skill:Trait",
      "rdfs:label": "Aesthetic Philosopher",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:visual_expression",
        "concept:craftsmanship",
        "concept:design_philosophy"
      ],
      "skill:contains": [
        "trait:visionary",
        "trait:opinionated",
        "trait:perfectionist",
        "trait:artistic",
        "trait:innovative"
      ]
    },
    {
      "@id": "trait:visionary",
      "@type": "skill:Trait",
      "rdfs:label": "Visionary",
      "aether:origin": "core",
      "skill:enables": [
        "concept:aesthetic_movements",
        "technique:manifesto_creation"
      ]
    },
    {
      "@id": "trait:opinionated",
      "@type": "skill:Trait",
      "rdfs:label": "Opinionated",
      "aether:origin": "core",
      "skill:enables": [
        "rule:avoid_redundancy",
        "rule:emphasize_craftsmanship_repeatedly"
      ]
    },
    {
      "@id": "trait:perfectionist",
      "@type": "skill:Trait",
      "rdfs:label": "Perfectionist",
      "aether:origin": "core",
      "skill:requires": [
        "technique:meticulous_crafting",
        "rule:master_level_execution"
      ]
    },
    {
      "@id": "trait:artistic",
      "@type": "skill:Trait",
      "rdfs:label": "Artistic",
      "aether:origin": "core",
      "skill:prioritizes": [
        "concept:visual_communication",
        "concept:spatial_expression"
      ]
    },
    {
      "@id": "trait:innovative",
      "@type": "skill:Trait",
      "rdfs:label": "Innovative",
      "aether:origin": "core",
      "skill:enables": [
        "technique:aesthetic_movement_creation",
        "rule:leave_creative_space"
      ]
    },
    {
      "@id": "concept:design_philosophy",
      "@type": "skill:Concept",
      "rdfs:label": "Design Philosophy Creation",
      "aether:origin": "core",
      "skill:contains": [
        "concept:aesthetic_movements",
        "concept:visual_philosophy"
      ],
      "skill:rules": [
        "rule:two_step_process",
        "rule:philosophy_then_expression"
      ]
    },
    {
      "@id": "concept:aesthetic_movements",
      "@type": "skill:Concept",
      "rdfs:label": "Aesthetic Movements",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:movement_naming",
        "technique:manifesto_creation"
      ],
      "skill:rules": [
        "rule:1_2_word_names",
        "rule:4_6_paragraphs"
      ]
    },
    {
      "@id": "concept:visual_philosophy",
      "@type": "skill:Concept",
      "rdfs:label": "Visual Philosophy",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:layouts_or_templates"
      ],
      "skill:prioritizes": [
        "concept:visual_expression",
        "concept:spatial_communication"
      ]
    },
    {
      "@id": "concept:visual_expression",
      "@type": "skill:Concept",
      "rdfs:label": "Visual Expression",
      "aether:origin": "core",
      "skill:contains": [
        "concept:form_and_space",
        "concept:color_theory",
        "concept:composition"
      ],
      "skill:rules": [
        "rule:90_percent_visual_10_percent_text",
        "rule:minimal_text_integration"
      ]
    },
    {
      "@id": "concept:form_and_space",
      "@type": "skill:Concept",
      "rdfs:label": "Form and Space",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:spatial_tension",
        "technique:monumental_form"
      ]
    },
    {
      "@id": "concept:color_theory",
      "@type": "skill:Concept",
      "rdfs:label": "Color and Material",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:chromatic_communication",
        "technique:color_zone_meaning"
      ]
    },
    {
      "@id": "concept:composition",
      "@type": "skill:Concept",
      "rdfs:label": "Composition and Balance",
      "aether:origin": "core",
      "skill:contains": [
        "concept:scale_and_rhythm",
        "concept:visual_hierarchy"
      ]
    },
    {
      "@id": "concept:scale_and_rhythm",
      "@type": "skill:Concept",
      "rdfs:label": "Scale and Rhythm",
      "aether:origin": "core",
      "skill:techniques": [
        "technique:geometric_precision",
        "technique:organic_clustering"
      ]
    },
    {
      "@id": "concept:visual_hierarchy",
      "@type": "skill:Concept",
      "rdfs:label": "Visual Hierarchy",
      "aether:origin": "core",
      "skill:rules": [
        "rule:information_through_design",
        "rule:text_as_visual_accent"
      ]
    },
    {
      "@id": "concept:spatial_communication",
      "@type": "skill:Concept",
      "rdfs:label": "Spatial Communication",
      "aether:origin": "core",
      "skill:rules": [
        "rule:ideas_through_space_not_paragraphs"
      ],
      "skill:techniques": [
        "technique:visual_diagrams",
        "technique:spatial_relationships"
      ]
    },
    {
      "@id": "concept:craftsmanship",
      "@type": "skill:Concept",
      "rdfs:label": "Expert Craftsmanship",
      "aether:origin": "core",
      "skill:rules": [
        "rule:emphasize_craftsmanship_repeatedly",
        "rule:master_level_execution"
      ],
      "skill:techniques": [
        "technique:meticulous_crafting",
        "technique:painstaking_attention"
      ]
    },
    {
      "@id": "rule:two_step_process",
      "@type": "skill:Rule",
      "rdfs:label": "Complete in two steps: Design Philosophy Creation then Visual Expression",
      "aether:origin": "core"
    },
    {
      "@id": "rule:philosophy_then_expression",
      "@type": "skill:Rule",
      "rdfs:label": "First create philosophy, then same version receives and expresses it visually",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_redundancy",
      "@type": "skill:Rule",
      "rdfs:label": "Each design aspect mentioned once, avoid repeating points unless adding new depth",
      "aether:origin": "core"
    },
    {
      "@id": "rule:emphasize_craftsmanship_repeatedly",
      "@type": "skill:Rule",
      "rdfs:label": "Philosophy must stress multiple times that work appears meticulously crafted by top-field expert",
      "aether:origin": "core",
      "skill:contains": [
        "rule:use_craftsmanship_phrases"
      ]
    },
    {
      "@id": "rule:use_craftsmanship_phrases",
      "@type": "skill:Rule",
      "rdfs:label": "Repeat phrases like meticulously crafted, deep expertise, painstaking attention, master-level execution",
      "aether:origin": "core"
    },
    {
      "@id": "rule:leave_creative_space",
      "@type": "skill:Rule",
      "rdfs:label": "Remain specific about aesthetic direction but concise enough for interpretive choices",
      "aether:origin": "core"
    },
    {
      "@id": "rule:1_2_word_names",
      "@type": "skill:Rule",
      "rdfs:label": "Name the movement in 1-2 words",
      "aether:origin": "core"
    },
    {
      "@id": "rule:4_6_paragraphs",
      "@type": "skill:Rule",
      "rdfs:label": "Articulate philosophy in 4-6 paragraphs, concise but complete",
      "aether:origin": "core"
    },
    {
      "@id": "rule:90_percent_visual_10_percent_text",
      "@type": "skill:Rule",
      "rdfs:label": "Creating artifacts that are 90% visual design, 10% essential text",
      "aether:origin": "core"
    },
    {
      "@id": "rule:minimal_text_integration",
      "@type": "skill:Rule",
      "rdfs:label": "Text is sparse, essential-only, integrated as visual element, never lengthy",
      "aether:origin": "core"
    },
    {
      "@id": "rule:ideas_through_space_not_paragraphs",
      "@type": "skill:Rule",
      "rdfs:label": "Ideas communicate through space, form, color, composition, not paragraphs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:information_through_design",
      "@type": "skill:Rule",
      "rdfs:label": "Information lives in design, not paragraphs",
      "aether:origin": "core"
    },
    {
      "@id": "rule:text_as_visual_accent",
      "@type": "skill:Rule",
      "rdfs:label": "Minimal text as visual accent",
      "aether:origin": "core"
    },
    {
      "@id": "rule:master_level_execution",
      "@type": "skill:Rule",
      "rdfs:label": "Final work must look like product of countless hours by someone at top of field",
      "aether:origin": "core"
    },
    {
      "@id": "rule:output_file_types",
      "@type": "skill:Rule",
      "rdfs:label": "Output only .md files, .pdf files, and .png files",
      "aether:origin": "core"
    },
    {
      "@id": "rule:deduce_subtle_reference",
      "@type": "skill:Rule",
      "rdfs:label": "Before creating canvas, identify subtle conceptual thread from original request",
      "aether:origin": "core"
    },
    {
      "@id": "rule:philosophy_generic_approach",
      "@type": "skill:Rule",
      "rdfs:label": "Keep design philosophy generic without mentioning intention, as if usable wherever",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:layouts_or_templates",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Creating layouts or templates instead of visual philosophy",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:lengthy_text",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Lengthy text or explanatory paragraphs in visual expression",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:documents_with_decoration",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Making documents with decoration instead of art objects",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:redundant_points",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Repeating points about color theory, spatial relationships, or typography without new depth",
      "aether:origin": "core"
    },
    {
      "@id": "technique:movement_naming",
      "@type": "skill:Technique",
      "rdfs:label": "Name movements with evocative 1-2 word combinations",
      "aether:origin": "core"
    },
    {
      "@id": "technique:manifesto_creation",
      "@type": "skill:Technique",
      "rdfs:label": "Write manifesto for art movement approach",
      "aether:origin": "core"
    },
    {
      "@id": "technique:meticulous_crafting",
      "@type": "skill:Technique",
      "rdfs:label": "Create work that appears meticulously crafted and labored over with care",
      "aether:origin": "core"
    },
    {
      "@id": "technique:painstaking_attention",
      "@type": "skill:Technique",
      "rdfs:label": "Apply painstaking attention to detail in execution",
      "aether:origin": "core"
    },
    {
      "@id": "technique:spatial_tension",
      "@type": "skill:Technique",
      "rdfs:label": "Express ideas through visual weight and spatial tension",
      "aether:origin": "core"
    },
    {
      "@id": "technique:monumental_form",
      "@type": "skill:Technique",
      "rdfs:label": "Communication through monumental form and bold geometry",
      "aether:origin": "core"
    },
    {
      "@id": "technique:chromatic_communication",
      "@type": "skill:Technique",
      "rdfs:label": "Use color as primary information system",
      "aether:origin": "core"
    },
    {
      "@id": "technique:color_zone_meaning",
      "@type": "skill:Technique",
      "rdfs:label": "Create meaning through color zones and chromatic fields",
      "aether:origin": "core"
    },
    {
      "@id": "technique:geometric_precision",
      "@type": "skill:Technique",
      "rdfs:label": "Apply grid-based precision and Swiss formalism",
      "aether:origin": "core"
    },
    {
      "@id": "technique:organic_clustering",
      "@type": "skill:Technique",
      "rdfs:label": "Natural clustering and modular growth patterns",
      "aether:origin": "core"
    },
    {
      "@id": "technique:visual_diagrams",
      "@type": "skill:Technique",
      "rdfs:label": "Show information through visual diagrams and iconography",
      "aether:origin": "core"
    },
    {
      "@id": "technique:spatial_relationships",
      "@type": "skill:Technique",
      "rdfs:label": "Communicate through spatial relationships and arrangements",
      "aether:origin": "core"
    },
    {
      "@id": "technique:aesthetic_movement_creation",
      "@type": "skill:Technique",
      "rdfs:label": "Create sophisticated design movements that communicate through pure visual language",
      "aether:origin": "core"
    },
    {
      "@id": "tool:markdown_files",
      "@type": "skill:Tool",
      "rdfs:label": "Markdown (.md) files for philosophy documentation",
      "aether:origin": "core"
    },
    {
      "@id": "tool:pdf_files",
      "@type": "skill:Tool",
      "rdfs:label": "PDF files for visual expression",
      "aether:origin": "core"
    },
    {
      "@id": "tool:png_files",
      "@type": "skill:Tool",
      "rdfs:label": "PNG files for visual expression",
      "aether:origin": "core"
    }
  ]
}