    {
      "@id": "rule:reference_specialized_guides",
      "@type": "skill:Rule",
      "rdfs:label": "Reference specialized guides for advanced features and forms",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_unicode_subscripts_superscripts",
      "@type": "skill:Rule",
      "rdfs:label": "Never use Unicode subscript/superscript characters in ReportLab PDFs",
      "aether:origin": "core",
      "skill:avoids": [
        "antipattern:unicode_subscripts_superscripts"
      ]
    },
    {
      "@id": "rule:use_reportlab_markup",
      "@type": "skill:Rule",
      "rdfs:label": "Use ReportLab XML markup tags for subscripts and superscripts",
      "aether:origin": "core",
      "skill:enables": [
        "technique:xml_markup_formatting"
      ]
    },
    {
      "@id": "rule:provide_complete_code_blocks",
      "@type": "skill:Rule",
      "rdfs:label": "Provide complete, executable code examples",
      "aether:origin": "core",
      "skill:enables": [
        "technique:comprehensive_examples"
      ]
    },
    {
      "@id": "antipattern:unicode_subscripts_superscripts",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Unicode subscript/superscript characters (₀₁₂₃₄₅₆₇₈₉, ⁰¹²³⁴⁵⁶⁷⁸⁹)",
      "aether:origin": "core"
    },
