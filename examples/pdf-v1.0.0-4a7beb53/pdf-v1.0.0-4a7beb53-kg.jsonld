    {
      "@id": "rule:use_pypdf_for_basic_operations",
      "@type": "skill:Rule",
      "rdfs:label": "Use pypdf for basic operations",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_pdfplumber_for_text_tables",
      "@type": "skill:Rule",
      "rdfs:label": "Use pdfplumber for text and table extraction",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_reportlab_for_creation",
      "@type": "skill:Rule",
      "rdfs:label": "Use reportlab for PDF creation",
      "aether:origin": "core"
    },
    {
      "@id": "rule:avoid_unicode_subscripts_superscripts",
      "@type": "skill:Rule",
      "rdfs:label": "Never use Unicode subscript/superscript characters in ReportLab PDFs",
      "aether:origin": "core",
      "skill:avoids": "antipattern:unicode_subscripts_superscripts"
    },
    {
      "@id": "rule:use_reportlab_xml_markup",
      "@type": "skill:Rule",
      "rdfs:label": "Use ReportLab XML markup tags for subscripts and superscripts",
      "aether:origin": "core",
      "skill:contradicts": "antipattern:unicode_subscripts_superscripts"
    },
    {
      "@id": "rule:check_table_not_empty",
      "@type": "skill:Rule",
      "rdfs:label": "Check if table is not empty before processing",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_pandas_for_table_processing",
      "@type": "skill:Rule",
      "rdfs:label": "Use pandas for table processing and export",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_pdfplumber_for_layout",
      "@type": "skill:Rule",
      "rdfs:label": "Use pdfplumber for layout-preserved text extraction",
      "aether:origin": "core"
    },
    {
      "@id": "rule:use_pytesseract_for_scanned",
      "@type": "skill:Rule",
      "rdfs:label": "Use pytesseract for scanned PDF text extraction",
      "aether:origin": "core"
    },
    {
      "@id": "rule:reference_forms_guide",
      "@type": "skill:Rule",
      "rdfs:label": "Read FORMS.md for PDF form filling instructions",
      "aether:origin": "core"
    },
    {
      "@id": "rule:reference_advanced_guide",
      "@type": "skill:Rule",
      "rdfs:label": "See REFERENCE.md for advanced features and JavaScript libraries",
      "aether:origin": "core"
    },
    {
      "@id": "antipattern:unicode_subscripts_superscripts",
      "@type": "skill:AntiPattern",
      "rdfs:label": "Unicode subscript/superscript characters (₀₁₂₃₄₅₆₇₈₉, ⁰¹²³⁴⁵⁶⁷⁸⁹)",
      "aether:origin": "core",
      "skill:contradicts": "rule:use_reportlab_xml_markup"
    }
  ]
}